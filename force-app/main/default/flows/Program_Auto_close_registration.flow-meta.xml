    </recordUpdates>
    <start>
        <locationX>564</locationX>
        <locationY>53</locationY>
        <connector>
            <targetReference>Is_total_participant_greater_then_max</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ProgramStatus__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Open for registration</stringValue>
            </value>
        </filters>
        <filters>
            <field>Max_Num_Of_Participants__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Program__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
