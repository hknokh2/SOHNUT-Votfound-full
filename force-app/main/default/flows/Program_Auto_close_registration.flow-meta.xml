    <decisions>
        <name>Is_total_participant_greater_then_max</name>
        <label>Is total participant greater then max</label>
        <locationX>696</locationX>
        <locationY>424</locationY>
        <defaultConnectorLabel>Not greater then max</defaultConnectorLabel>
        <rules>
            <name>Greater_then_max</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Num_of_Registered__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Max_Num_Of_Participants__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Close_registration</targetReference>
            </connector>
            <label>Greater then max</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>Program - Auto close registration {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Program - Auto close registration</label>
