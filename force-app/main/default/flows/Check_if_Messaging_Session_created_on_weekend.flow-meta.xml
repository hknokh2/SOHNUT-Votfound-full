    <environments>Default</environments>
    <formulas>
        <name>DayOfWeek</name>
        <dataType>String</dataType>
        <expression>CASE(
WEEKDAY(DATEVALUE( {!ReturnedDateTimeValuesFromApex})),
1, &quot;Sunday&quot;,
2, &quot;Monday&quot;,
3, &quot;Tuesday&quot;,
4, &quot;Wednesday&quot;,
5, &quot;Thursday&quot;,
6, &quot;Friday&quot;,
7, &quot;Saturday&quot;,
&quot;Unknown&quot;
)</expression>
    </formulas>
    <formulas>
        <name>hour</name>
        <dataType>Number</dataType>
        <expression>10/24</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>IsAfterThursdayAfternoon</name>
        <dataType>Boolean</dataType>
        <expression>OR(
  VALUE(MID({!ReturnedDateTimeValuesFromApex}, 12, 2)) &gt; 16,
  AND(
    VALUE(MID({!ReturnedDateTimeValuesFromApex}, 12, 2)) = 16,
    VALUE(MID({!ReturnedDateTimeValuesFromApex}, 15, 2)) &gt;= 30
  )
)</expression>
    </formulas>
    <formulas>
        <name>IsBeforeSundayWorkHours</name>
        <dataType>Boolean</dataType>
        <expression>VALUE(MID({!ReturnedDateTimeValuesFromApex}, 12, 2))&lt;8</expression>
    </formulas>
    <formulas>
        <name>PastWorkHours</name>
        <dataType>Boolean</dataType>
        <expression>OR(
  (NOW() - DATETIMEVALUE(TEXT(DATEVALUE(NOW())) &amp; &quot; 00:00:00&quot;)) &lt; (8/24),
  (NOW() - DATETIMEVALUE(TEXT(DATEVALUE(NOW())) &amp; &quot; 00:00:00&quot;)) &gt; (17/24)
)</expression>
    </formulas>
    <formulas>
        <name>TimeOfDay</name>
        <dataType>Boolean</dataType>
        <expression>OR(
  VALUE(MID({!ReturnedDateTimeValuesFromApex}, 12, 2)) &lt; 8,
  VALUE(MID({!ReturnedDateTimeValuesFromApex}, 12, 2)) &gt; 16,
  AND(
    VALUE(MID({!ReturnedDateTimeValuesFromApex}, 12, 2)) = 16,
    VALUE(MID({!ReturnedDateTimeValuesFromApex}, 15, 2)) &gt;= 30
  )
)</expression>
    </formulas>
    <formulas>
        <name>TimeRecordCreated</name>
        <dataType>String</dataType>
        <expression>MID(TEXT({!Get_Messaging_Session.CreatedDate}), 12, 5)</expression>
    </formulas>
