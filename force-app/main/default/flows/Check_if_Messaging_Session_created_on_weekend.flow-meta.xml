    <decisions>
        <name>isWeekend</name>
        <label>isWeekend</label>
        <locationX>50</locationX>
        <locationY>566</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Thursday</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>DayOfWeek</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Thursday</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsAfterThursdayAfternoon</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Record_that_it_was_created_during_weekend</targetReference>
            </connector>
            <label>Thursday</label>
        </rules>
        <rules>
            <name>During_Weekend</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>DayOfWeek</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Friday</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DayOfWeek</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Saturday</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Record_that_it_was_created_during_weekend</targetReference>
            </connector>
            <label>During Weekend</label>
        </rules>
        <rules>
            <name>Sunday</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IsBeforeSundayWorkHours</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DayOfWeek</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Sunday</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Record_that_it_was_created_during_weekend</targetReference>
            </connector>
            <label>Sunday</label>
        </rules>
        <rules>
            <name>Other_No_service_time</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Blackout_Times.Id</leftValueReference>
                <operator>NotEqualTo</operator>
            </conditions>
            <connector>
                <targetReference>Update_Record_to_created_on_Other_No_service_time</targetReference>
            </connector>
            <label>Other No service time</label>
        </rules>
        <rules>
            <name>After_work_hours</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>TimeOfDay</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Record_to_Created_after_work_hours</targetReference>
            </connector>
            <label>After work hours</label>
        </rules>
    </decisions>
