        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Speaks_Arabic</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Contact.Languages__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Arabic</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Route_to_Speaks_Arabic</targetReference>
            </connector>
            <label>Speaks Arabic</label>
        </rules>
        <rules>
            <name>Has_Multiple_Casualties</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Contact.Multiple_Casualties__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Route_to_MultipleCasualties</targetReference>
            </connector>
            <label>Has Multiple Casualties</label>
        </rules>
        <rules>
            <name>Related_to_Nova</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Contact.Related_to_nova__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Route_to_RelatedtoNova</targetReference>
            </connector>
            <label>Related to Nova</label>
        </rules>
        <rules>
            <name>Lives_in_Southern_Settlement</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Contact.MailingCity</leftValueReference>
