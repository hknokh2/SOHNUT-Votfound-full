                </rightValue>
            </conditions>
            <connector>
                <targetReference>Route_to_outhernSettlements</targetReference>
            </connector>
            <label>Lives in Southern Settlement</label>
        </rules>
        <rules>
            <name>Lives_in_other_Southern_Cities</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Contact.MailingCity</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>נתיבות</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Contact.MailingCity</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>אשקלון</stringValue>
